# ─── Groq API Key ──────────────────────────────────────────────────────────
# Get your API key from: https://console.groq.com
# Optional – if not set, the system uses rule‑based fallback.
GROQ_API_KEY=your-groq-api-key-here

# ─── SMTP Email Configuration ────────────────────────────────────────────
# Gmail is recommended. Use an App Password (not your regular password).
# How to get a Gmail App Password:
#   1. Enable 2‑Factor Authentication on your Google account.
#   2. Go to Security → App passwords → Generate for "Mail".
#   3. Copy the 16‑character password (remove spaces).

SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-16-character-app-password-no-spaces
PROPRIETOR_EMAIL=recipient@example.com

# ─── SMTP Server Settings (Gmail default) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ─── Alert Threshold ──────────────────────────────────────────────────────
# Determines which severity levels trigger email alerts.
# Options: high (only CRITICAL/HIGH), medium (also MEDIUM), low (all).
ALERT_THRESHOLD=high

# ─── Flask Server Port ────────────────────────────────────────────────────
# Optional – default is 5000.
PORT=5000
